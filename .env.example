# Copy to .env before running. Production mode refuses weak defaults.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Optional and recommended for production. Takes precedence over ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=
# JWT signing key is auto-generated on first start and stored at ./keys/jwt.key.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DB_PATH=./data/bookkeeping.db
PORT=3000
BEHIND_CDN=false
